# MongoDB connection URI (Legacy/Optional - MongoDB integration is retired in v2.4+)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/database

# GitHub Releases API URL for native update checks
MAIN_VITE_GITHUB_RELEASES_URL=https://api.github.com/repos/Shaik-Nagur-Basha/ClipMaster-Pro/releases

# Runtime override for GitHub Releases API URL (Optional)
GITHUB_RELEASES_URL=

# Custom secret key for database/settings encryption (Optional)
CLIPMASTER_SECRET=
